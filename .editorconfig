root = true

# ─── Defaults (all files) ────────────────────────────────────────────────────
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# ─── Java ────────────────────────────────────────────────────────────────────
[*.java]
indent_size = 4
max_line_length = 120

# ─── Python ──────────────────────────────────────────────────────────────────
[*.py]
indent_size = 4
max_line_length = 88

# ─── TypeScript / JavaScript ─────────────────────────────────────────────────
[*.{ts,tsx,js,mjs,cjs}]
indent_size = 2
max_line_length = 100

# ─── Terraform ───────────────────────────────────────────────────────────────
[*.{tf,tfvars}]
indent_size = 2

# ─── Data / Config ───────────────────────────────────────────────────────────
[*.{json,yaml,yml,toml}]
indent_size = 2

# ─── Markdown ────────────────────────────────────────────────────────────────
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# ─── Makefiles (tabs required) ───────────────────────────────────────────────
[Makefile]
indent_style = tab

# ─── Shell scripts ───────────────────────────────────────────────────────────
[*.sh]
indent_size = 2
end_of_line = lf
